# GOVWORLD Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to git

# === REQUIRED FOR LIVE MODE ===

# Google Gemini 2.5 Flash — get from aistudio.google.com (free)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq — get from console.groq.com (free)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Deepgram Aura TTS — get from console.deepgram.com (free tier)
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cesium Ion — get from cesium.com/ion (free account)
VITE_CESIUM_TOKEN=your_cesium_ion_token_here

# Google Maps — get from console.cloud.google.com (Maps Tile API, free tier)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Browserbase — get from browserbase.com. Powers live council-expert web
# research (Search + Fetch). Server-side ONLY — not prefixed VITE_, so it is
# never bundled into the browser. Used by api/research.ts and server/dev.ts.
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# === DEMO MODE (no API keys needed) ===

# Set to 'true' to run entirely from pre-computed JSON — no API calls
VITE_DEMO_MODE=false

# Skip all API calls (forces demo data even if keys present)
VITE_SKIP_API=false

# Which neighbourhood to load in demo
VITE_DEMO_NEIGHBOURHOOD=andheri

# Auto-run demo on load (for unattended demos)
VITE_AUTO_DEMO=false
